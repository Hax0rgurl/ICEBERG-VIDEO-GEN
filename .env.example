# Server port
PORT=3000

# API key for Gemini (Used for both text and image generation)
# Supports Gemini 2.5 Flash (Text) and Gemini 2.5 Flash Image (Nano Banana)
GEMINI_API_KEY=your_gemini_api_key_here

# API key used by Odyssey for video generation
ODYSSEY_API_KEY=your_odyssey_api_key_here

# Allowed origin for CORS (frontend origin)
CORS_ORIGIN=http://localhost:3000

# JSON body size limit for requests
JSON_LIMIT=1mb
